<UserControl x:Class="SkyLauncher.Views.ToolboxPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SkyLauncher.Views"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      >

    <Grid Margin="10">
        <StackPanel>
        <Button Margin="10" Height="40" HorizontalAlignment="Left" Width="150" Style="{StaticResource ButtonDefault}" Click="FlipClock_Show">
            <DockPanel>
                <iconPacks:PackIconLucide Kind="CalendarClock" Foreground="{DynamicResource PrimaryNormalBrush}" Width="18" Height="18"/>
                <TextBlock Text="桌面时钟" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Button>
        </StackPanel>
    </Grid>
</UserControl>
