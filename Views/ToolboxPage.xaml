<UserControl x:Class="SkyLauncher.Views.ToolboxPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SkyLauncher.Views"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      >
    <Border CornerRadius="4" Padding="10" Margin="10" Background="{DynamicResource RegionBrush}">
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="59*"/>
                <ColumnDefinition Width="721*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                <Button Margin="10" Height="40" HorizontalAlignment="Left" Width="150" Style="{StaticResource ButtonDefault}" Click="FlipClock_Show">
                    <DockPanel>
                        <iconPacks:PackIconLucide Kind="CalendarClock" Foreground="{DynamicResource PrimaryNormalBrush}" Width="18" Height="18"/>
                        <TextBlock Text="桌面时钟" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                </Button>
            </StackPanel>

            <TabControl Grid.Row="1" Grid.ColumnSpan="2" x:Name="MainTabControl" Style="{StaticResource TabControlSliding}">
                <TabItem Visibility="Hidden" Width="0">
                    <hc:TransitioningContentControl TransitionMode="Right2LeftWithFade" />
                </TabItem>
                <TabItem Header="主题色" FontSize="15" >
                    <hc:TransitioningContentControl TransitionMode="Right2LeftWithFade" x:Name="ThemeTransition">
                        <hc:ScrollViewer>

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Padding="10" Margin="10,0,10,0">
                                <StackPanel Width="500">
                                    <hc:Divider Padding="0" Content="选择一个主题色"/>
                                    <hc:ColorPicker Name="ColorPicker" SelectedColorChanged="ColorPicker_OnSelectedColorChanged" Grid.Column="0" Confirmed="ColorPicker_ColorConfirmed"/>
                                </StackPanel>
                            </Border>

                        </hc:ScrollViewer>
                    </hc:TransitioningContentControl>

                </TabItem>
                <TabItem Header="背景图片" FontSize="15">
                    <hc:TransitioningContentControl TransitionMode="Right2LeftWithFade">
                        <Border >
                            <StackPanel Margin="10" Width="500">
                                <hc:Divider Padding="0" Content="选择背景图片"/>
                                <hc:ImageSelector Width="100" Height="100" hc:BorderElement.CornerRadius="10" StrokeThickness="2" BorderThickness="2" BorderBrush="{DynamicResource PrimaryBrush}" x:Name="ImageSelector"/>
                                <Button Content="确认" Margin="0,20,0,0" x:Name="SelectPicBtn" Click="ConfirmSelectPic" FontSize="15" Height="35" Width="60" Style="{DynamicResource ButtonPrimary}"/>
                            </StackPanel>
                        </Border>
                    </hc:TransitioningContentControl>
                </TabItem>
                <TabItem Header="切换明暗模式" FontSize="15">
                    <hc:TransitioningContentControl TransitionMode="Right2LeftWithFade">
                        <Border Margin="15,10,10,10">
                            <StackPanel Width="500">
                                <hc:Divider Padding="0" Content="明暗模式设定"/>
                                <StackPanel HorizontalAlignment="Left">
                                    <RadioButton Content="Light" HorizontalAlignment="Left" Margin="15,10,10,0" Click="SwitchToLight"/>
                                    <RadioButton Content="Dark" HorizontalAlignment="Left" Margin="15,10,10,0" Click="SwitchToDark"/>
                                    <TextBlock Text="因一些原因无法实现" Margin="15,10,10,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </hc:TransitioningContentControl>
                </TabItem>
                <TabItem Header="透明度设定" FontSize="15">
                    <hc:TransitioningContentControl TransitionMode="Right2LeftWithFade">
                        <Border>
                            <StackPanel Margin="10" Width="500">
                                <hc:Divider Padding="0" Content="透明度设定" />
                                <Slider Width="400" Maximum="1" Minimum="0.25"  x:Name="OpacitySlider" hc:TipElement.Visibility="Visible" 
 IsSelectionRangeEnabled="True" SelectionStart="0.5" SelectionEnd="0.9" TickFrequency="0.025" IsSnapToTickEnabled="True" TickPlacement="TopLeft"/>
                                <Button Content="确认" Margin="0,20,0,0" x:Name="OpacityConfirmBtn" Click="ConfirmOpacity" FontSize="15" Height="35" Width="60" Style="{DynamicResource ButtonPrimary}"/>
                            </StackPanel>
                        </Border>
                    </hc:TransitioningContentControl>
                </TabItem>
            </TabControl>

        </Grid>
    </Border>
</UserControl>
