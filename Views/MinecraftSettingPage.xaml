<UserControl x:Class="SkyLauncher.Views.MinecraftSettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:SkyLauncher.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="4" Padding="10" Margin="10" Background="{DynamicResource RegionBrush}">
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <hc:Divider Content="{Binding MinecraftName}" Grid.Row="0" Margin="15,15,15,10" FontSize="15"/>

                <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding Mods}" 
                      hc:DataGridAttach.ShowRowNumber="True"
                      AutoGenerateColumns="False"
                      x:Name="ModsDataGrid" Opacity="0.9">
                    <DataGrid.Columns>
                        <DataGridTextColumn  Width="400" Header="名称" Binding="{Binding FileName}" IsReadOnly="True" />
                        <DataGridTextColumn Width="130" Header="大小" Binding="{Binding FormattedSize}" IsReadOnly="True" />
                        <DataGridCheckBoxColumn Header="状态" CanUserResize="False"  Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            <Grid x:Name="LoadingGrid" Visibility="Hidden">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Border VerticalAlignment="Center" Grid.Column="1" Background="{DynamicResource PrimaryBrush}" CornerRadius="10">
                    <StackPanel>
                        <hc:LoadingCircle Style="{StaticResource LoadingCircleLight}" Margin="10"/>
                        <TextBlock Text=" "/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
