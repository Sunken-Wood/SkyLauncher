<UserControl x:Class="SkyLauncher.Views.ConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SkyLauncher.Views"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      >

    <Grid>
        <ScrollViewer>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <GroupBox Header="通用配置项" FontSize="15" Grid.Row="0" Margin="10" Padding="10" Style="{StaticResource GroupBoxTab}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Grid.Row="0">
                            <StackPanel 
                                HorizontalAlignment="Left">
                                <TextBlock Text="配置内存使用" Margin="20,10,20,10" />
                                <DockPanel
                                    HorizontalAlignment="Left"
                                    Margin="10">
                                    <RadioButton
                                        x:Name="manual_allocation"
                                        GroupName="mem_allocation_mode"
                                        Content="手动分配"
                                        
                                        IsChecked="{Binding IsManualCollocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <hc:UniformSpacingPanel Orientation="Vertical" Spacing="32">
                                        <Slider Width="400" 
                                                hc:TipElement.Visibility="Visible" 
                                                hc:TipElement.Placement="Top" 
                                                IsSnapToTickEnabled="True" 
                                                Minimum="1024"
                                                Maximum="{Binding FreeMemory}"
                                                Value="{Binding MaxMemory, UpdateSourceTrigger=PropertyChanged}" 
                                                IsEnabled="{Binding IsManualCollocation}"
                                                TickFrequency="128" 
                                                TickPlacement="BottomRight" 
                                                HorizontalAlignment="Left" 
                                                Margin="20,0,0,15"
                                                />
                                    </hc:UniformSpacingPanel>
                                    <TextBlock Text="{Binding MaxMemory, StringFormat='当前设置: {0} MB'}" Margin="20,0,20,10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </DockPanel>
                                <DockPanel
                                    HorizontalAlignment="Left"
                                    Margin="10">
                                    <RadioButton
                                        GroupName="mem_allocation_mode"
                                        Content="自动分配"
                                        IsChecked="{Binding IsAutoCollocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                </DockPanel>
                            </StackPanel>

                        </Border>
                        <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Grid.Row="1" Margin="0,15,0,0">
                            <StackPanel>
                                
                                    <TextBlock Text="选择Java" Margin="20,10,20,0"/>

                                <ToolBar Margin="15,10,15,15" Band="1">
                                    <TextBlock Text="选择Java版本" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox Margin="10,0,0,0" 
          ItemsSource="{Binding JavaList}" 
          SelectedItem="{Binding SelectedJava}" 
          DisplayMemberPath="DisplayText" 
          Width="230" />

                                    
                                    <hc:ButtonGroup>
                                    <Button Content="添加" Margin="15,0,0,0"  FontSize="15"
        Command="{Binding AddJavaCommand}" Style="{StaticResource ButtonPrimary}"/>

                                    <Button 
              Content="自动寻找Java" Margin="15,0,0,0" FontSize="15" 
              Command="{Binding AutoDetectJavaCommand}"/>
                                    </hc:ButtonGroup>
                                </ToolBar>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource RegionBrush}" Grid.Row="2" Margin="0,15,0,0">
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border CornerRadius="5" Width="150" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0" >
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <iconPacks:PackIconPhosphorIcons Kind="CropBold" Width="35" Height="35" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100">
                                            <TextBlock Text="截图画廊" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                            <Button 
                    
                    Content="打开"  
                    FontSize="13" 
                    Height="30"
                    Width="60" 
                    Click="OpenScreenshotGallery"
                    Margin="20,0,20,5" Grid.Row="1"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="1" CornerRadius="5" Width="150" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <iconPacks:PackIconPhosphorIcons Kind="PackageBold" Width="35" Height="35" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100">
                                            <TextBlock Text="资源包" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                            <Button 
                    
                    Content="打开"  
                    FontSize="13" 
                    Height="30"
                    Width="60" 
                    Click="OpenResourcePackManager"
                  Margin="20,0,20,5" Grid.Row="1"/>

                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="2" CornerRadius="5" Width="150" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <iconPacks:PackIconPhosphorIcons Kind="SphereBold" Width="35" Height="35" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100">
                                            <TextBlock Text="光影包" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                            <Button 
                    
                    Content="打开"  
                    FontSize="13" 
                    Height="30"
                    Width="60" 
                    Margin="20,0,20,5" Grid.Row="1"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="3" CornerRadius="5" Width="150" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <iconPacks:PackIconPhosphorIcons Kind="VideoCameraBold" Width="35" Height="35" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="150">
                                            <TextBlock Text="投影" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                            <Button 
                    
                    Content="打开"  
                    FontSize="13" 
                    Height="30"
                    Width="60" 
                    Margin="20,0,20,5" Grid.Row="1"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </GroupBox>
                <GroupBox Header="可传递配置项" FontSize="15" Grid.Row="1" Margin="10" Padding="10" Style="{StaticResource GroupBoxTab}">
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="4">
                        <TextBlock Text="未实现" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                </GroupBox>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
