<UserControl x:Class="SkyLauncher.Views.SchematicsManage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SkyLauncher.Views"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Padding="10" Margin="10" >
            <StackPanel Orientation="Horizontal" >
                <Button  Width="110" Margin="0,0,10,0" Click="OpenSchematicsFilesFolder"
    >
                    <DockPanel>
                        <iconPacks:PackIconPhosphorIcons Kind="FolderOpen" />
                        <TextBlock Text="打开文件夹" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                </Button>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="10,0,10,0">
            <DataGrid
ItemsSource="{Binding DataList}"
AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTextColumn
        Header="投影文件"
        Width="*"
        Binding="{Binding FileName}" />



                </DataGrid.Columns>

            </DataGrid>
        </Border>
    </Grid>

</UserControl>
