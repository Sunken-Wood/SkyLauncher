<UserControl x:Class="SkyLauncher.Views.DownloadPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SkyLauncher.Views"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="4" Padding="10" Margin="10" Background="{DynamicResource RegionBrush}">
        <Grid>


            <TabControl Style="{StaticResource TabControlSliding}">
                <TabItem Visibility="Hidden" Width="0">
                    <hc:TransitioningContentControl TransitionMode="Right2LeftWithFade" />
                </TabItem>
                <TabItem Header="安装整合包" FontSize="15">
                    <hc:TransitioningContentControl TransitionMode="Right2LeftWithFade" >
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Button x:Name="PackPicker" 
                            Command="{Binding PickPackageCommand}"
                            Grid.Row="0" 
                            Margin="0,5,0,5"
                            Height="40"
                
                            IsEnabled="{Binding IsInstalling, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                <DockPanel>
                                    <iconPacks:PackIconLucide Kind="FolderOpenDot" Margin="0,0,10,0"/>
                                    <TextBlock Text="选择整合包文件（.zip / .mrpack）" FontSize="14"/>
                                </DockPanel>
                            </Button>

                            <Grid
            Grid.Row="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Margin="0,20,0,0"
                    Opacity="0.9">

                                <Border Background="{DynamicResource RegionBrush}" CornerRadius="4">
                                    <StackPanel>
                                        <hc:CircleProgressBar Value="{Binding Progress}" 
                                  FontSize="30" 
                                  Width="100" 
                                  Height="100"
                                  Visibility="{Binding IsInstalling, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,10,0,0"/>
                                        <TextBlock Text="{Binding StatusText}" 
   FontSize="14" 
   HorizontalAlignment="Center" 
   Margin="30,10,30,10"
   TextWrapping="Wrap"
   MaxWidth="400"
   TextAlignment="Center"/>
                                    </StackPanel>

                                </Border>

                            </Grid>

                            <Border Grid.Row="2" 
                Background="{DynamicResource RegionBrush}" 
                CornerRadius="8" 
                Padding="20" 
                Margin="0,20,0,0"
                VerticalAlignment="Bottom"
                Opacity="0.9">

                                <Border>

                                    <StackPanel>
                                        <DockPanel>
                                            <iconPacks:PackIconLucide Kind="FileArchive" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text=" .mrpack — Modrinth 整合包" Margin="0,2,0,2"/>
                                        </DockPanel>
                                        <DockPanel>
                                            <iconPacks:PackIconLucide Kind="FileArchive" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text=".zip — CurseForge 整合包" Margin="0,2,0,2" />
                                        </DockPanel>

                                    </StackPanel>

                                </Border>

                            </Border>
                            <Border Style="{StaticResource BorderTipDanger}" Grid.Row="3" Margin="5,10,5,0">
                                <DockPanel>
                                    <iconPacks:PackIconOcticons Kind="Alert16" Height="25" Width="25" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#e04f5e"/>
                                    <StackPanel>
                                        <TextBlock Text="安装前需要配置好Java环境" Foreground="#e04f5e"/>
                                        <TextBlock Text="安装过程中不要切换页面" Foreground="#e04f5e"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </hc:TransitioningContentControl>
                </TabItem>
                <TabItem Header="安装Java JDK" FontSize="15">
                    <hc:TransitioningContentControl TransitionMode="Right2LeftWithFade" >

                    </hc:TransitioningContentControl>
                </TabItem>
            </TabControl>

        </Grid>
    </Border>
</UserControl>