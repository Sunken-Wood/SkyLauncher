<UserControl x:Class="SkyLauncher.Views.ResourcePackManager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SkyLauncher.Views"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--hc:Divider Grid.Row="0" Content="资源包管理" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/-->
        <Border Grid.Row="0">
            <DataGrid
    ItemsSource="{Binding DataList}"
    AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTextColumn
            Header="资源包"
            Width="*"
            Binding="{Binding FileName}" />

                    <DataGridCheckBoxColumn
            Header="启用"
            Width="80"
            Binding="{Binding IsEnabled,
                      UpdateSourceTrigger=PropertyChanged}" />

                </DataGrid.Columns>

            </DataGrid>
        </Border>


        <Button Grid.Row="1" Content="保存" Command="{Binding SaveCommand}"
                Width="100" HorizontalAlignment="Right" Margin="0,15,0,0"/>
    </Grid>
</UserControl>