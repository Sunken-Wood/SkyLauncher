<UserControl x:Class="SkyLauncher.Views.ScreenshotGallery"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SkyLauncher.Views"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Opacity="0.85">
        <StackPanel>
        
        <!-- 顶部工具栏 -->
        <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Padding="10" Margin="10" >
            <StackPanel Orientation="Horizontal">
                    <Button Width="80" Margin="0,0,10,0"
                        Click="RefreshButton_Click">
                        <DockPanel>
                            <iconPacks:PackIconPhosphorIcons Kind="ArrowsClockwiseLight" />
                            <TextBlock Text="刷新" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Button>
                    <Button  Width="110" Margin="0,0,10,0"
                        Click="OpenFolderButton_Click">
                        <DockPanel>
                            <iconPacks:PackIconPhosphorIcons Kind="FolderOpen" />
                            <TextBlock Text="打开文件夹" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Button>
                    <TextBlock Text="{Binding ScreenshotCount, StringFormat='共 {0} 张截图'}" 
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBlock Text="{Binding ScreenshotFolderPath}" 
                           VerticalAlignment="Center" Margin="20,0,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300"/>
            </StackPanel>
        </Border>

        <hc:TransitioningContentControl>
        <hc:Carousel Grid.Row="1" 
                     Margin="0" 
                     IsCenter="True" 
                     AutoRun="True"
                     ItemsSource="{Binding Screenshots}"
                     Visibility="Visible">
            <hc:Carousel.ItemTemplate>
                <DataTemplate>
                    <Grid>

                            <Border Background="#111"
                    CornerRadius="10"
                    Padding="5">

                                <Image Source="{Binding Thumbnail}"
                       Stretch="Uniform"
                       MaxWidth="700"
                       MaxHeight="400"/>
                            </Border>
                            <Border VerticalAlignment="Bottom"
                    Background="#88000000"
                    CornerRadius="0,0,10,10"
                    Padding="10">

                            <StackPanel>

                                <TextBlock Text="{Binding FileName}"
                               Foreground="White"
                               FontWeight="SemiBold"/>

                                <TextBlock Text="{Binding CreateTime}"
                               Foreground="#DDDDDD"
                               FontSize="11"/>

                            </StackPanel>

                        </Border>

                    </Grid>
                </DataTemplate>
            </hc:Carousel.ItemTemplate>
        </hc:Carousel>
        </hc:TransitioningContentControl>

        </StackPanel>
    </Grid>
</UserControl>