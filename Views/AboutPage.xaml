<UserControl x:Class="SkyLauncher.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SkyLauncher.Views"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="10">
            <TextBlock Text="SkyLauncher" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="内部人员预览 版本alpha 1.0.2" FontSize="14" Margin="0,4,0,20"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="15*"/>
                    <ColumnDefinition Width="15*"/>
                    <ColumnDefinition Width="30*"/>
                </Grid.ColumnDefinitions>
                <hc:Shield Subject=".NET运行库" Status=".NET8" Color="LightGray" HorizontalAlignment="Left"/>
                <hc:Shield Subject="Windows" Status="7+" Color="LightGray" Grid.Column="1" HorizontalAlignment="Left"/>
                <hc:Shield Subject="HandyControl" Status="3.5.1" Color="LightGray" Grid.Column="2" HorizontalAlignment="Left"/>
            </Grid>
            
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="10">
            <TextBlock Text="SkyLauncher 是一个基于 WPF 的启动器，旨在给整合包作者提供高度自定义的页面" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="开发者：zydrawer   SunkenWood" Margin="0,0,0,5"/>
          
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="10">
            <TextBlock Text="界面控件来自 HandyControl，图标来自 MahApps " TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="核心逻辑使用了Xcube-Studio的Natsurainko.FluentCore" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="尊重原作者的MIT协议，若Xcube认为侵权请联系我们整改" Margin="0,0,0,5"/>
        </StackPanel>
    </Grid>
</UserControl>
