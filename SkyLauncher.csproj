<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows7.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <SupportedOSPlatformVersion>7.0</SupportedOSPlatformVersion>
    <ApplicationIcon>ChatGPT Image 2026年7月5日 10_21_17~1.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Views\FlipClock.xaml.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Background.png" />
    <None Remove="Background_Blur.png" />
  </ItemGroup>

  <ItemGroup>
    <Page Remove="Views\FlipClock.xaml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="FluentWpfCore" Version="1.0.4" />
    <PackageReference Include="HandyControl" Version="3.5.1" />
    <PackageReference Include="MahApps.Metro.IconPacks" Version="6.2.1" />
    <PackageReference Include="MahApps.Metro.IconPacks.Material" Version="6.2.1" />
    <PackageReference Include="NbtToolkit" Version="0.1.2-beta" />
    <PackageReference Include="System.Text.Json" Version="10.0.8" />
    <PackageReference Include="Tomlyn" Version="2.4.0" />
    <PackageReference Include="unknown6656.WPFPixelShaderLibrary" Version="1.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="ChatGPT Image 2026年7月5日 10_21_17~1.ico" />
    <Content Include="Background.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Background_Blur.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
